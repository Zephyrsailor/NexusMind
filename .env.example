# NexusMind 环境变量配置示例
# 复制此文件为 .env 并填入实际的值

# LLM配置
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# RabbitMQ配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=nexusmind
RABBITMQ_PASSWORD=nexusmind123
RABBITMQ_VHOST=/

# ChromaDB配置
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_COLLECTION=nexusmind_memory

# 应用配置
APP_NAME="NexusMind Orchestrator"
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8080

# Agent配置
ORCHESTRATOR_AGENT_ID=orchestrator
MAX_CONCURRENT_TASKS=100
TASK_TIMEOUT_SECONDS=300

# A2A协议配置
A2A_EXCHANGE_NAME=nexusmind.agents
A2A_RESPONSE_TIMEOUT=30

# =================================
# 多模态模型配置
# =================================

# 多模态大模型 (选择一个)
MULTIMODAL_MODEL=Qwen/Qwen-VL-Chat  # 推荐：中文效果好
# MULTIMODAL_MODEL=llava-hf/llava-1.5-7b-hf  # 备选：英文效果好

# 启用本地模型
USE_LOCAL_MODELS=true

# Google Cloud服务
# GOOGLE_CREDENTIALS_PATH=/path/to/google-credentials.json
# GOOGLE_PROJECT_ID=your-google-project-id

# Azure认知服务
# AZURE_SPEECH_KEY=your-azure-speech-key
# AZURE_SPEECH_REGION=your-azure-region
# AZURE_VISION_KEY=your-azure-vision-key
# AZURE_VISION_ENDPOINT=https://your-region.api.cognitive.microsoft.com/

# =================================
# 本地模型配置
# =================================

# Whisper本地模型
WHISPER_MODEL_SIZE=large  # tiny, base, small, medium, large
ENABLE_LOCAL_WHISPER=true

# =================================
# 多模态处理配置
# =================================

# 文件大小限制
MAX_IMAGE_SIZE_MB=10
MAX_AUDIO_DURATION_SECONDS=300
MAX_VIDEO_DURATION_SECONDS=600

# 临时文件目录
TEMP_DIR=/tmp/nexusmind

# 服务质量配置
HIGH_QUALITY_THRESHOLD=0.8
ENABLE_FALLBACK_PROVIDERS=true
MAX_PROCESSING_TIME_SECONDS=60