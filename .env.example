# NexusMind 环境配置

# 应用配置
APP_NAME="NexusMind Orchestrator"
APP_VERSION="1.0.0"
DEBUG=true

# 服务器配置
HOST="0.0.0.0"
PORT=8080

# Redis配置
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""

# RabbitMQ配置
RABBITMQ_HOST="localhost"
RABBITMQ_PORT=5672
RABBITMQ_USER="nexusmind"
RABBITMQ_PASSWORD="nexusmind123"
RABBITMQ_VHOST="/"

# ChromaDB配置
CHROMADB_HOST="localhost"
CHROMADB_PORT=8000
CHROMADB_COLLECTION="nexusmind_memory"

# LLM配置 (请设置您的API密钥)
LLM_PROVIDER="openai"
LLM_MODEL="gpt-3.5-turbo"
LLM_API_KEY="your-api-key-here"
LLM_BASE_URL=""
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Agent配置
ORCHESTRATOR_AGENT_ID="orchestrator"
MAX_CONCURRENT_TASKS=100
TASK_TIMEOUT_SECONDS=300

# A2A协议配置
A2A_EXCHANGE_NAME="nexusmind.agents"
A2A_RESPONSE_TIMEOUT=30